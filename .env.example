# ==============================================================================
# portfolio-v2 environment configuration (12-Factor III)
# Copy to `.env` on the server and fill in real values. `.env` is gitignored.
# ==============================================================================

# Flask session signing key. REQUIRED in production (app refuses to boot without
# it when FLASK_ENV=production). Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to "production" on the live server so SECRET_KEY is enforced and debug off.
FLASK_ENV=production

# Local dev only: set to 1/true to enable the Werkzeug debugger. NEVER in prod.
FLASK_DEBUG=

# Bind address / port for `python app.py` (gunicorn overrides these).
HOST=127.0.0.1
PORT=5001

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Admin content routes (/admin) are gated by this key. If unset, /admin is
# locked entirely (returns 404). Pass via ?key=... or X-Admin-Key header.
ADMIN_KEY=

# Telegram satisfaction-rating notifications (optional). If unset, /api/rate
# still records the rating but skips the notify. Rotate these before production.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OAuth (currently stubbed — callbacks not yet completing token exchange)
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
